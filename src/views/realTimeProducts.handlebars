<div class="container mt-5">
    <h1 class="text-center mb-5 fw-bold text-dark">
        <i class="fas fa-tools text-primary"></i> Panel de Control (Real Time)
    </h1>

    {{> buscador}}

    <div class="row">
        {{!-- COLUMNA IZQUIERDA: FORMULARIO VERTICAL --}}
        <div class="col-md-4">
            <div class="card shadow border-0 p-4 sticky-top" style="top: 20px;">
                <h4 class="text-primary fw-bold mb-3">Nuevo Producto</h4>
                <hr>
                <form id="productForm">
                    <div class="mb-3">
                        <label class="form-label fw-bold small">TÍTULO</label>
                        <input type="text" id="title" class="form-control" placeholder="Nombre..." required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small">IMAGEN</label>
                        <input type="file" id="imageInput" class="form-control" accept="image/*">
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small">DESCRIPCIÓN</label>
                        <input type="text" id="description" class="form-control" placeholder="Detalles..." required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small">PRECIO</label>
                        <input type="number" id="price" class="form-control" placeholder="0.00" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small">STOCK</label>
                        <input type="number" id="stock" class="form-control" placeholder="Cantidad" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small">CATEGORÍA</label>
                        <select id="category" class="form-select" required>
                            <option value="" disabled selected>Selecciona una categoría...</option>
                            <option value="Celulares">Celulares</option>
                            <option value="Accesorios">Accesorios</option>
                            <option value="Almacenamiento">Almacenamiento</option>
                            <option value="Audio">Audio</option>
                            <option value="Componentes">Componentes</option>
                            <option value="Monitores">Monitores</option>
                            <option value="Muebles">Muebles</option>
                            <option value="Periféricos">Periféricos</option>
                            <option value="Redes">Redes</option>
                        </select>
                    </div>
                    <input type="hidden" id="code" value="AUTO">
                    <button type="submit" class="btn btn-primary w-100 fw-bold py-2 mt-2">Crear Producto</button>
                </form>
            </div>
        </div>

        {{!-- COLUMNA DERECHA: LISTADO --}}
        <div class="col-md-8">
            <div id="productsContainer" class="row g-3">
            </div>
        </div>
    </div>
</div>

{{> filtros}}

<script src="/socket.io/socket.io.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="/js/realTime.js"></script>
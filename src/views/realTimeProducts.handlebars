<div class="container mt-5">
    <h1 class="text-center mb-4">Panel de Control (Real Time)</h1>

    <div class="row">
        <div class="col-md-4">
            <div class="card shadow p-4 sticky-top" style="top: 20px;">
                <h4 class="text-primary">Nuevo Producto</h4>
                <hr>
                <form id="productForm">
                    <div class="mb-3">
                        <label class="form-label font-weight-bold">Título</label>
                        <input type="text" id="title" class="form-control" placeholder="Ej: iPhone 15" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label font-weight-bold">Descripción</label>
                        <input type="text" id="description" class="form-control" placeholder="Breve descripción" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label font-weight-bold">Precio</label>
                        <input type="number" id="price" class="form-control" placeholder="Ej: 999" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label font-weight-bold">Código</label>
                        <input type="text" id="code" class="form-control" placeholder="Ej: P001" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label font-weight-bold">Stock</label>
                        <input type="number" id="stock" class="form-control" placeholder="Ej: 10" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label font-weight-bold">Categoría</label>
                        <input type="text" id="category" class="form-control" placeholder="Ej: Celulares" required>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 shadow-sm">
                        <i class="fas fa-plus-circle"></i> Crear Producto
                    </button>
                </form>
            </div>
        </div>

        <div class="col-md-8">
            <h4 class="mb-3">Listado de Productos</h4>
            <div id="productsContainer" class="row">
                {{#each products}}
                <div class="col-md-6 mb-3">
                    <div class="card h-100 p-3 border-primary shadow-sm">
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">{{this.title}}</h5>
                            <p class="text-muted small mb-1">ID: {{this.id}}</p>
                            <p class="card-text text-secondary small">{{this.description}}</p>
                            <p class="fw-bold text-success fs-5">${{this.price}}</p>
                            <button class="btn btn-danger btn-sm mt-auto" onclick="deleteProduct('{{this.id}}')">
                                <i class="fas fa-trash"></i> Eliminar
                            </button>
                        </div>
                    </div>
                </div>
                {{/each}}
            </div>
        </div>
    </div>
</div>

{{!-- Scripts de Socket.io y lógica del cliente --}}
<script src="/socket.io/socket.io.js"></script>
<script src="/realTime.js"></script> 

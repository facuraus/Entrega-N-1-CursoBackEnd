<link rel="stylesheet" href="/css/productStyles.css">

<div class="container mt-5">
    <h1 class="text-center mb-5 fw-bold text-dark">
        <i class="fas fa-store text-primary"></i> Catálogo de Productos
    </h1>

    {{!-- IMPORTACIÓN DE COMPONENTES --}}
    {{> buscador}}
    {{> filtros}}

    <div class="row row-cols-1 row-cols-md-3 g-4">
        {{#each productos}}
        <div class="col">
            <div class="card h-100 shadow-sm border-0 transition-hover">
                <div class="text-center p-3 bg-light rounded-top position-relative">
                    {{#if this.stock}}
                        {{!-- <span class="badge bg-success position-absolute top-0 start-0 m-3">Stock: {{this.stock}}</span> --}}
                    {{else}}
                        <span class="badge bg-danger position-absolute top-0 start-0 m-3">Agotado</span>
                    {{/if}}

                    {{#if this.thumbnails.[0]}}
                    <img src="/assets/img/{{this.thumbnails.[0]}}" class="card-img-top img-fluid" style="height: 200px; object-fit: contain;" onerror="this.src='https://via.placeholder.com/200?text=Error+Imagen'">
                    {{else}}
                    <img src="https://via.placeholder.com/200x200?text=Sin+Imagen" class="card-img-top img-fluid" style="height: 200px; object-fit: contain;">
                    {{/if}}
                </div>

                <div class="card-body d-flex flex-column">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <h5 class="card-title mb-0 fw-bold text-truncate" style="max-width: 70%;">{{this.title}}</h5>
                        <span class="badge bg-info text-dark">{{this.category}}</span>
                    </div>

                    <div class="text-start my-2">
                        <span class="fs-3 fw-bold text-success">${{this.price}}</span>
                    </div>

                    <div class="mt-auto d-grid gap-2">
                        <a href="/products/{{this._id}}" class="btn btn-outline-secondary btn-sm fw-bold">
                            <i class="fas fa-eye"></i> Ver Detalles
                        </a>

                        {{!-- Lógica de Botón según Stock --}}
                        {{#if this.stock}}
                            <button class="btn btn-primary btn-sm fw-bold" onclick="addToCart('{{this._id}}')">
                                <i class="fas fa-cart-plus"></i> Agregar al Carrito
                            </button>
                        {{else}}
                            <button class="btn btn-secondary btn-sm fw-bold disabled" disabled>
                                <i class="fas fa-times-circle"></i> Sin Stock
                            </button>
                        {{/if}}
                    </div>
                </div>
            </div>
        </div>
        {{/each}}
    </div>

    {{!-- Paginación --}}
    <nav class="mt-5 mb-5">
        <ul class="pagination justify-content-center shadow-sm">
            {{#if pagination.hasPrevPage}}
            <li class="page-item"><a class="page-link py-2 px-4" href="{{pagination.prevLink}}">&laquo; Anterior</a></li>
            {{/if}}
            <li class="page-item disabled">
                <span class="page-link py-2 px-4 fw-bold text-dark bg-light">Página {{pagination.page}} de {{pagination.totalPages}}</span>
            </li>
            {{#if pagination.hasNextPage}}
            <li class="page-item"><a class="page-link py-2 px-4" href="{{pagination.nextLink}}">Siguiente &raquo;</a></li>
            {{/if}}
        </ul>
    </nav>
</div>

<script src="/socket.io/socket.io.js"></script> 
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="/js/productView.js"></script>
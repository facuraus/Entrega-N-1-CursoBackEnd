<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="fas fa-shopping-cart text-primary"></i> Tu Carrito</h1>
        <div class="d-flex gap-2">
            <a href="/historial" class="btn btn-outline-success">
                <i class="fas fa-history"></i> Mis Compras
            </a>
            <a href="/products" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left"></i> Seguir Comprando
            </a>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            {{#if productos.length}}
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Producto</th>
                                <th class="text-center">Cantidad</th>
                                <th class="text-end">Precio Unitario</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#each productos}}
                            <tr>
                                <td>
                                    <div class="fw-bold">{{this.product.title}}</div>
                                    <small class="text-muted">{{this.product.category}}</small>
                                </td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center align-items-center gap-2">
                                        <button class="btn btn-sm btn-light border" 
                                                onclick="cartActions.updateQty('{{../cartId}}', '{{this.product._id}}', {{this.quantity}} - 1)">-</button>
                                        <span class="badge bg-secondary fs-6">{{this.quantity}}</span>
                                        <button class="btn btn-sm btn-light border" 
                                                onclick="cartActions.updateQty('{{../cartId}}', '{{this.product._id}}', {{this.quantity}} + 1)">+</button>
                                    </div>
                                </td>
                                <td class="text-end">${{this.product.price}}</td>
                                <td class="text-center">
                                    <button class="btn btn-outline-danger btn-sm" onclick="cartActions.removeItem('{{../cartId}}', '{{this.product._id}}')">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </td>
                            </tr>
                            {{/each}}
                        </tbody>
                    </table>
                </div>

                <div class="d-flex justify-content-end mt-4">
                    <button class="btn btn-danger" onclick="cartActions.emptyCart('{{cartId}}')">
                        <i class="fas fa-trash-alt"></i> Vaciar Carrito
                    </button>
                    <button class="btn btn-success ms-2" onclick="cartActions.checkout()">
                        Finalizar Compra <i class="fas fa-check"></i>
                    </button>
                </div>
            {{else}}
                <div class="text-center py-5">
                    <i class="fas fa-shopping-basket fa-4x text-muted mb-3 opacity-50"></i>
                    <p class="fs-4 text-muted">Tu carrito está vacío</p>
                    <div class="d-flex justify-content-center gap-2">
                        <a href="/products" class="btn btn-primary">Ir a la tienda</a>
                        <a href="/historial" class="btn btn-outline-success">Ver mis compras pasadas</a>
                    </div>
                </div>
            {{/if}}
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="/js/cart.js"></script>